# ─── Token Configuration ──────────────────────────────────────
# JSON map of agent write tokens → identity
# Format: {"token_value": {"agent_id": "matrim", "display_name": "Matrim"}}
AGENT_TOKENS={"dev-token-matrim": {"agent_id": "matrim", "display_name": "Matrim"}, "dev-token-perrin": {"agent_id": "perrin", "display_name": "Perrin"}}

# Bearer token for TRMNL read endpoint
TRMNL_READ_TOKEN=dev-read-token

# ─── Database ─────────────────────────────────────────────────
DATABASE_URL=sqlite:///data/status.db

# ─── Application ──────────────────────────────────────────────
ENVIRONMENT=dev
LOG_LEVEL=DEBUG

# ─── GCP Deployment ──────────────────────────────────────────
GCP_PROJECT=your-gcp-project-id
GCP_REGION=us-central1
AR_REPO=trmnl-agent-dashboard
SERVICE_NAME=status-board
